# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Voyage AI ─────────────────────────────────────────
VOYAGE_API_KEY=pa-...

# ── Polygon.io (two free accounts) ────────────────────
POLYGON_API_KEY_1=your_first_polygon_key
POLYGON_API_KEY_2=your_second_polygon_key

# ── GCP ───────────────────────────────────────────────
GCP_PROJECT_ID=signal-platform-2026
GCP_CLOUD_SQL_CONNECTION_NAME=signal-platform-2026:us-central1:signal-db
GCP_REGION=us-central1

# ── Database ──────────────────────────────────────────
# For `docker compose` Airflow + scheduler, compose overrides DB_HOST=postgres and DB_PORT=5432 so ingestion and in-container dbt reach the Postgres service. Host-only scripts (local dbt/psql) keep localhost:5433 below.
DB_NAME=signal
DB_USER=signal_user
DB_PASSWORD=your_strong_password_here
DB_HOST=localhost
DB_PORT=5433

# ── LangSmith ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=signal-development

# ── Signal API ────────────────────────────────────────
SIGNAL_API_KEY=generate_a_random_32_char_string_here

# ── Logo.dev (Rule-3 amendment 2026-05-14 — Clearbit Logo API replacement) ──
LOGO_DEV_TOKEN=pk_your_logo_dev_publishable_key_here

# ── Frontend (set in Vercel environment variables) ────
VITE_API_URL=http://localhost:8000
VITE_SIGNAL_KEY=same_as_signal_api_key_above

# ── LLM Models (Rule-3 amendment 2026-05-12 — see plan amendments log) ──
LLM_MODEL_PRODUCTION=gpt-4o-mini
LLM_MODEL_FALLBACK=gpt-5-nano

# ── SEC EDGAR (Rule-3 amendment 2026-05-13 — see plan amendments log) ──
EDGAR_USER_AGENT_EMAIL=harthikmallichetty@gmail.com
